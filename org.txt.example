# Organization Token Mapping
#
# Format: organization_name=api_token
#
# Example:
# Engineering=$ENGINEERING_TOKEN
# Marketing=$MARKETING_TOKEN
#
# Usage:
#   cp org.txt.example org.txt
#   Edit org.txt with your organization names and tokens
#   Run: ./org-migration.sh --organization Engineering

# Add your organizations below (one per line)
# Engineering=<your-engineering-token-here>
# Marketing=<your-marketing-token-here>
# Sales=<your-sales-token-here>
