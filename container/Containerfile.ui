FROM registry.redhat.io/ubi9/nodejs-20-minimal:latest AS builder

USER 0
WORKDIR /build
COPY web/package.json web/package-lock.json* ./
RUN [ -f package-lock.json ] && npm ci || npm install
COPY web/ ./
RUN npm run build

RUN chown -R 1001:0 /build
USER 1001


FROM registry.redhat.io/ubi9/ubi-minimal:9.4

# hadolint ignore=DL3041
RUN microdnf install -y nginx && microdnf clean all

RUN rm -rf /etc/nginx/conf.d/* /usr/share/nginx/html/* && \
    mkdir -p /var/log/nginx /var/cache/nginx /tmp /etc/nginx/auth /etc/nginx/conf.d && \
    touch /etc/nginx/auth/.htpasswd && \
    chown -R 1001:0 /var/log/nginx /var/cache/nginx /tmp /usr/share/nginx/html /etc/nginx

COPY --from=builder /build/dist /usr/share/nginx/html
COPY container/nginx.conf /etc/nginx/nginx.conf
COPY container/start-nginx.sh /usr/local/bin/start-nginx.sh

EXPOSE 8080

USER 1001

CMD ["/bin/sh", "/usr/local/bin/start-nginx.sh"]
